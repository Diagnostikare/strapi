{
  "collectionName": "components_labs_labs_tags",
  "info": {
    "displayName": "LabsTag",
    "icon": "book"
  },
  "options": {},
  "attributes": {
    "label": {
      "type": "string"
    },
    "shortLabel": {
      "type": "string"
    },
