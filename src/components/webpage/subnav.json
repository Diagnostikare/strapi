{
  "collectionName": "components_webpage_subnavs",
  "info": {
    "displayName": "Subnav",
    "icon": "apps",
    "description": ""
  },
  "options": {},
  "attributes": {
    "description": {
      "type": "text"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "Options": {
      "displayName": "options",
      "type": "component",
      "repeatable": true,
      "component": "webpage.options"
    },
    "name": {
      "type": "string"
    },
    "background": {
      "type": "customField",
      "regex": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$",
      "customField": "plugin::color-picker.color"
    }
  }
}
