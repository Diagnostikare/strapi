{
  "kind": "collectionType",
  "collectionName": "service_themes",
  "info": {
    "singularName": "service-theme",
    "pluralName": "service-themes",
    "displayName": "serviceTheme"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "buttonColor": {
      "type": "customField",
      "regex": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$",
      "customField": "plugin::color-picker.color",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "buttonText": {
      "type": "customField",
      "regex": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$",
      "customField": "plugin::color-picker.color",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "bannerBg": {
      "type": "customField",
      "regex": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$",
      "customField": "plugin::color-picker.color",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "buttonHighlight": {
      "type": "customField",
      "regex": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$",
      "customField": "plugin::color-picker.color",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "service_flows": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::service-flow.service-flow",
      "mappedBy": "service_theme"
    }
  }
}
