{
  "kind": "collectionType",
  "collectionName": "org_roles",
  "info": {
    "singularName": "org-role",
    "pluralName": "org-roles",
    "displayName": "OrgRole"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "is_system": {
      "type": "boolean",
      "default": false,
      "required": false
    },
    "organization": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::organization.organization",
      "inversedBy": "org_roles"
    },
    "general_permissions": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::general-permission.general-permission",
      "inversedBy": "org_roles"
    }
  }
}
